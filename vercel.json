{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "acceluav-flyers.pdf",
          "acceluav-profile.pdf",
          "index.html",
          "styles.css",
          "script.js"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "^/([a-z0-9\\-]+\\.pdf)$",
      "dest": "server.js"
    },
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "server.js"
    }
  ]
}
